  \r\n
  function syncMatakuliahMeta(value) {\r\n
      const option = matakuliahSelect.querySelector(`option[value="${value}"]`);\r\n
  \r\n
      matakuliahKodePreview.value = option?.dataset.kode || '';\r\n
      matakuliahSksPreview.value = option?.dataset.sks || '';\r\n
  }\r\n
  \r\n
  function editJadwal(id, data) {\r\n
      formTitle.textContent = 'Ô£Å´©Å Edit Jadwal';\r\n
      methodEl.value = 'PUT';\r\n
      jadwalIdEl.value = id;\r\n
      formEl.action = `/baak/jadwal/${id}`;\r\n
      btnCancel.classList.remove('hidden');\r\n
  \r\n
      formEl.querySelector('[name=matakuliah_id]').value = data.matakuliah_id;\r\n
      formEl.querySelector('[name=dosen_id]').value = data.dosen_id;\r\n
      formEl.querySelector('[name=ruangan_id]').value = data.ruangan_id;\r\n
      formEl.querySelector('[name=prodi]').value = data.prodi;\r\n
      formEl.querySelector('[name=semester]').value = data.semester;\r\n
      formEl.querySelector('[name=hari]').value = data.hari;\r\n
      formEl.querySelector('[name=waktu_mulai]').value = data.waktu_mulai.substring(0,5);\r\n
      formEl.querySelector('[name=waktu_selesai]').value = data.waktu_selesai.substring(0,5);\r\n
      syncMatakuliahMeta(String(data.matakuliah_id));\r\n
      formEl.scrollIntoView({ behavior: 'smooth' });\r\n
  }\r\n
  \r\n
  function resetForm() {\r\n
      formTitle.textContent = 'Ô×ò Input Jadwal BAAK';\r\n
      methodEl.value = 'POST';\r\n
      formEl.action = 'http://localhost/baak/jadwal';\r\n
      formEl.reset();\r\n
      btnCancel.classList.add('hidden');\r\n
      syncMatakuliahMeta(matakuliahSelect.value);\r\n
  }\r\n
  \r\n
  matakuliahSelect.addEventListener('change', (event) => {\r\n
      syncMatakuliahMeta(event.target.value);\r\n
